# Copy to .env and adjust for your environment
PORT=8080
COGNEE_BASE_URL=https://api.cognee.ai
COGNEE_API_KEY=
COGNEE_FALLBACK_FAILURE_THRESHOLD=3
COGNEE_FALLBACK_COOLDOWN=1m
COGNEE_FALLBACK_TIMEOUT=60s
COGNEE_EXPOSE_UPSTREAM_ERRORS=false
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_AUTH_ENABLED=false
