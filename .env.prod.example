# Production Environment Variables
# Copy to .env.prod and fill in actual values for your deployment

# Database Configuration (REQUIRED)
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=your_secure_password_here

# Cognee Configuration (REQUIRED)
COGNEE_API_KEY=your_cognee_api_key_here
COGNEE_BASE_URL=https://api.cognee.ai
COGNEE_REQUEST_TIMEOUT=60s
COGNEE_FALLBACK_FAILURE_THRESHOLD=3
COGNEE_FALLBACK_COOLDOWN=1m

# LLM Configuration (REQUIRED)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Frontend Configuration
VITE_BACKEND_URL=http://backend:8080

# Supabase Configuration (Optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_AUTH_ENABLED=false

# Dataset Configuration
DATASET_WORKSPACE=/data/workspace

# Application Settings
PORT=8080
COGNEE_EXPOSE_UPSTREAM_ERRORS=false
